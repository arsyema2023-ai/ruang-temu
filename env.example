:root {
  --bg: #081522;
  --ink: #f7fbff;
  --muted: rgba(247, 251, 255, .68);
  --muted-2: rgba(247, 251, 255, .46);
  --glass: rgba(255, 255, 255, .12);
  --stroke: rgba(255, 255, 255, .22);
  --deep: rgba(4, 18, 35, .48);
  --aqua: #7ceeff;
  --violet: #a7a2ff;
  --mint: #92ffd3;
  --shadow: 0 28px 80px rgba(0, 0, 0, .35);
}

* { box-sizing: border-box; }
html { min-height: 100%; background: var(--bg); }
body { margin: 0; min-height: 100%; color: var(--ink); font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
button, input { font: inherit; }
button, a { -webkit-tap-highlight-color: transparent; }

.app {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 22px;
  background:
    radial-gradient(circle at 10% 10%, rgba(124, 238, 255, .24), transparent 34%),
    radial-gradient(circle at 85% 14%, rgba(167, 162, 255, .25), transparent 34%),
    linear-gradient(135deg, #071421, #0e2038 48%, #06242d);
}

.water-bg { position: fixed; inset: 0; pointer-events: none; overflow: hidden; }
.blob {
  position: absolute;
  width: 44vw;
  height: 44vw;
  border-radius: 38% 62% 58% 42% / 42% 42% 58% 58%;
  filter: blur(18px);
  opacity: .45;
  mix-blend-mode: screen;
  animation: liquid 18s ease-in-out infinite alternate;
}
.b1 { left: -12vw; top: 10vh; background: rgba(124, 238, 255, .42); }
.b2 { right: -18vw; top: 3vh; background: rgba(167, 162, 255, .42); animation-duration: 21s; }
.b3 { left: 28vw; bottom: -24vw; background: rgba(146, 255, 211, .28); animation-duration: 24s; }
.wave {
  position: absolute;
  left: -20%;
  width: 140%;
  height: 200px;
  border-radius: 50%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.12), transparent);
  transform: rotate(-3deg);
  animation: wave 13s ease-in-out infinite;
}
.w1 { bottom: 7%; }
.w2 { bottom: 13%; animation-duration: 18s; opacity: .55; }

@keyframes liquid {
  0% { transform: translate3d(0, 0, 0) scale(1); border-radius: 38% 62% 58% 42% / 42% 42% 58% 58%; }
  50% { transform: translate3d(6vw, -4vh, 0) scale(1.08); border-radius: 55% 45% 35% 65% / 55% 35% 65% 45%; }
  100% { transform: translate3d(-2vw, 5vh, 0) scale(.96); border-radius: 48% 52% 66% 34% / 34% 55% 45% 66%; }
}
@keyframes wave {
  0%, 100% { transform: translateX(-6%) rotate(-3deg); }
  50% { transform: translateX(6%) rotate(2deg); }
}
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }

.glass {
  background: linear-gradient(135deg, rgba(255,255,255,.16), rgba(255,255,255,.06));
  border: 1px solid var(--stroke);
  box-shadow: var(--shadow), inset 0 1px 0 rgba(255,255,255,.18);
  backdrop-filter: blur(24px) saturate(140%);
  -webkit-backdrop-filter: blur(24px) saturate(140%);
}
.deep { background: linear-gradient(135deg, rgba(255,255,255,.16), rgba(6, 18, 33, .42)); }

.topbar {
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 14px;
  align-items: center;
  max-width: 1180px;
  margin: 0 auto;
  padding: 12px;
  border-radius: 28px;
}
.brand, .quiet, .nav, .action-card, .primary, .secondary { cursor: pointer; border: 0; color: var(--ink); }
.brand { display: flex; gap: 12px; align-items: center; background: transparent; text-align: left; }
.brand-mark { display: grid; place-items: center; width: 44px; height: 44px; border-radius: 16px; background: linear-gradient(135deg, rgba(124,238,255,.7), rgba(167,162,255,.65)); color: #061421; font-weight: 900; }
.brand small { display: block; color: var(--muted-2); margin-top: 2px; }
.nav-actions { display: flex; justify-content: center; gap: 6px; flex-wrap: wrap; }
.nav, .quiet { padding: 10px 14px; border-radius: 999px; background: rgba(255,255,255,.06); }
.nav.active { background: rgba(255,255,255,.22); }
.quiet { background: rgba(255,255,255,.1); color: var(--muted); }

.hero {
  position: relative;
  z-index: 2;
  max-width: 1180px;
  margin: 68px auto 0;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: 24px;
  align-items: stretch;
}
.hero-copy, .panel { border-radius: 42px; padding: clamp(24px, 4vw, 56px); }
.eyebrow { margin: 0 0 12px; text-transform: uppercase; letter-spacing: .16em; font-size: 12px; color: var(--mint); font-weight: 800; }
h1, h2, h3, p { margin-top: 0; }
h1 { max-width: 760px; margin-bottom: 14px; font-size: clamp(44px, 8vw, 96px); line-height: .92; letter-spacing: -0.075em; }
h2 { margin-bottom: 12px; font-size: clamp(34px, 5vw, 68px); line-height: .95; letter-spacing: -0.055em; }
h3 { margin-bottom: 8px; font-size: 20px; }
.lead { max-width: 760px; color: var(--muted); font-size: 20px; line-height: 1.6; }
.lead.small { font-size: 16px; }

.action-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 32px; }
.action-card { position: relative; display: grid; gap: 10px; padding: 20px; border-radius: 28px; text-align: left; transition: transform .25s ease, background .25s ease; }
.action-card:hover { transform: translateY(-5px); background: rgba(255,255,255,.18); }
.action-icon { display: grid; place-items: center; width: 52px; height: 52px; border-radius: 19px; background: rgba(255,255,255,.14); font-size: 26px; color: var(--aqua); }
.action-card small, .item p, .room-result p { color: var(--muted); line-height: 1.5; }

.phone { position: relative; min-height: 520px; border-radius: 46px; padding: 22px; overflow: hidden; animation: float 7s ease-in-out infinite; }
.phone-glow { position: absolute; inset: 70px 26px auto; height: 220px; background: radial-gradient(circle, rgba(124,238,255,.58), transparent 65%); filter: blur(12px); }
.phone-top { position: relative; width: 86px; height: 26px; margin: 0 auto 36px; border-radius: 999px; background: rgba(0,0,0,.32); }
.mood-card { position: relative; padding: 22px; border-radius: 30px; background: rgba(255,255,255,.16); border: 1px solid rgba(255,255,255,.18); }
.mood-card span { color: var(--muted); }
.mood-card strong { display: block; font-size: 28px; margin-top: 8px; letter-spacing: -.04em; }
.mini-orb { width: 160px; height: 160px; margin: 44px auto; border-radius: 48% 52% 58% 42% / 45% 38% 62% 55%; background: radial-gradient(circle at 30% 30%, #fff, var(--aqua) 26%, var(--violet) 64%, rgba(255,255,255,.1)); box-shadow: 0 0 70px rgba(124,238,255,.42); animation: liquid 10s ease-in-out infinite alternate; }
.mini-list { display: grid; gap: 10px; }
.mini-list p { margin: 0; padding: 14px 16px; border-radius: 18px; background: rgba(255,255,255,.1); color: var(--muted); }

.panel { position: relative; z-index: 2; max-width: 900px; margin: 64px auto 0; }
.focus-panel { max-width: 760px; }
.input-wrap { display: grid; gap: 10px; margin: 24px 0; color: var(--muted); }
input { width: 100%; padding: 16px 18px; border-radius: 18px; border: 1px solid rgba(255,255,255,.2); outline: 0; color: var(--ink); background: rgba(0,0,0,.18); }
input:focus { border-color: rgba(124,238,255,.66); box-shadow: 0 0 0 4px rgba(124,238,255,.12); }
.progress { height: 12px; overflow: hidden; border-radius: 999px; background: rgba(255,255,255,.12); }
.progress span { display: block; height: 100%; border-radius: inherit; background: linear-gradient(90deg, var(--aqua), var(--mint)); transition: width .3s ease; }
.button-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px; }
.primary, .secondary { display: inline-flex; align-items: center; justify-content: center; padding: 14px 18px; border-radius: 999px; font-weight: 800; text-decoration: none; }
.primary { background: linear-gradient(135deg, var(--aqua), var(--violet)); color: #061421; }
.primary:disabled { opacity: .55; cursor: not-allowed; }
.secondary { background: rgba(255,255,255,.12); }
.insight, .room-result { margin-top: 22px; padding: 18px; border-radius: 24px; color: var(--muted); }
.insight strong { color: var(--ink); }
.cards { display: grid; gap: 12px; margin-top: 24px; }
.item { display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 18px; border-radius: 26px; }
.pill { display: inline-flex; margin-bottom: 10px; padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: 800; color: #061421; background: rgba(146,255,211,.9); }
.link { margin-top: 12px; }

.reduce-motion *, .reduce-motion *::before, .reduce-motion *::after { animation: none !important; transition: none !important; }

@media (max-width: 920px) {
  .app { padding: 14px; }
  .topbar { grid-template-columns: 1fr; }
  .nav-actions { justify-content: flex-start; overflow-x: auto; flex-wrap: nowrap; padding-bottom: 2px; }
  .hero { grid-template-columns: 1fr; margin-top: 28px; }
  .phone { min-height: 360px; }
  .action-grid { grid-template-columns: 1fr; }
  .panel { margin-top: 28px; }
  .hero-copy, .panel { border-radius: 32px; }
  .item { align-items: flex-start; flex-direction: column; }
}
